@model IEnumerable<AnToanBaoMat.Models.User>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>👥 Quản lý người dùng</h2>

        <a asp-action="Create" class="btn btn-success">
            <i class="fa fa-plus"></i> Thêm User
        </a>
    </div>

    <input class="form-control mb-3"
           id="searchUser"
           placeholder="🔍 Tìm kiếm người dùng..." />

    <table class="table table-hover table-bordered align-middle">

        <thead class="table-dark">

            <tr>

                <th>ID</th>

                <th>Họ tên</th>

                <th>Email</th>

                <th>Role</th>

                <th>Trạng thái</th>

                <th width="220">Thao tác</th>

            </tr>

        </thead>

        <tbody id="userTable">

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.UserId</td>

                    <td>@item.FullName</td>

                    <td>@item.Email</td>

                    <td>

                        @if (item.Role == "Admin")
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else if (item.Role == "Employer")
                        {
                            <span class="badge bg-warning text-dark">Employer</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Candidate</span>
                        }

                    </td>

                    <td>

                        <span class="badge bg-success">
                            Hoạt động
                        </span>

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.UserId"
                           class="btn btn-warning btn-sm">

                            Sửa

                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.UserId"
                           class="btn btn-info btn-sm">

                            Chi tiết

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.UserId"
                           class="btn btn-danger btn-sm">

                            Xóa

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<script>

    document.getElementById("searchUser").addEventListener("keyup",function(){

    let value=this.value.toLowerCase();

    let rows=document.querySelectorAll("#userTable tr");

    rows.forEach(r=>{

    r.style.display=r.innerText.toLowerCase().includes(value)
    ?"":"none";

    });

    });

</script>