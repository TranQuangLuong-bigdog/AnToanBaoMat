@model IEnumerable<AnToanBaoMat.Models.CvuploadLog>

@{
    ViewData["Title"] = "Upload Logs";
}

<div class="container mt-4">

    <h2>

        Nhật ký Upload CV

    </h2>

    <hr>

    <table id="logTable"
           class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>ID</th>

                <th>User</th>

                <th>Job</th>

                <th>IP</th>

                <th>File</th>

                <th>Upload</th>

                <th>Status</th>

                <th></th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {

                <tr>

                    <td>@item.Id</td>

                    <td>@item.User?.FullName</td>

                    <td>@item.Job?.JobTitle</td>

                    <td>@item.Ipaddress</td>

                    <td>@item.FileName</td>

                    <td>@item.UploadTime</td>

                    <td>

                        @if (item.Status == "Thành công")
                        {
                            <span class="badge bg-success">

                                Thành công

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">

                                Thất bại

                            </span>
                        }

                    </td>

                    <td>

                        <a asp-action="Detail"
                           asp-route-id="@item.Id"
                           class="btn btn-primary btn-sm">

                            Chi tiết

                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>

@section Scripts {

    <script>

        $(function(){

        $("#logTable").DataTable({

        responsive:true,

        pageLength:10,

        language:{

        url:"//cdn.datatables.net/plug-ins/1.13.8/i18n/vi.json"

        }

        });

        });

    </script>

}