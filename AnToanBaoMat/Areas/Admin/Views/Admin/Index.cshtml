@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Center";
}

<div class="container-fluid mt-4">

    <h2 class="fw-bold">

        ⚙️ Admin Center

    </h2>

    <hr />

    <div class="row">

        <div class="col-lg-3 mb-4">

            <div class="card admin-card bg-primary">

                <i class="fa-solid fa-users fa-3x"></i>

                <h2>@ViewBag.TotalUser</h2>

                <p>Người dùng</p>

            </div>

        </div>

        <div class="col-lg-3 mb-4">

            <div class="card admin-card bg-success">

                <i class="fa-solid fa-briefcase fa-3x"></i>

                <h2>@ViewBag.TotalJob</h2>

                <p>Công việc</p>

            </div>

        </div>

        <div class="col-lg-3 mb-4">

            <div class="card admin-card bg-warning">

                <i class="fa-solid fa-file fa-3x"></i>

                <h2>@ViewBag.TotalCV</h2>

                <p>CV</p>

            </div>

        </div>

        <div class="col-lg-3 mb-4">

            <div class="card admin-card bg-danger">

                <i class="fa-solid fa-ban fa-3x"></i>

                <h2>@ViewBag.TotalBlocked</h2>

                <p>Blocked IP</p>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-lg-12">

            <div class="card shadow">

                <div class="card-header">

                    Chức năng quản trị

                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="Dashboard"
                               asp-action="Index"
                               class="btn btn-outline-primary w-100">

                                Dashboard

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="Application"
                               asp-action="Index"
                               class="btn btn-outline-success w-100">

                                Quản lý CV

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="BlockedIp"
                               asp-action="Index"
                               class="btn btn-outline-danger w-100">

                                Blocked IP

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="Security"
                               asp-action="Index"
                               class="btn btn-outline-dark w-100">

                                Security

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="CvUploadLog"
                               asp-action="Index"
                               class="btn btn-outline-info w-100">

                                Upload Logs

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="User"
                               asp-action="Index"
                               class="btn btn-outline-secondary w-100">

                                Người dùng

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="Job"
                               asp-action="Index"
                               class="btn btn-outline-warning w-100">

                                Công việc

                            </a>

                        </div>

                        <div class="col-md-3 mb-3">

                            <a asp-area="Admin"
                               asp-controller="Report"
                               asp-action="Index"
                               class="btn btn-outline-primary w-100">

                                Báo cáo

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>