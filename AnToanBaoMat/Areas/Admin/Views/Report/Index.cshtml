@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Report Center";
}

<div class="container-fluid">

    <h2 class="mb-4">

        📊 Report Center

    </h2>

    <div class="row">

        <div class="col-lg-3">

            <div class="card report-card bg-primary">

                <h1>@ViewBag.TotalUpload</h1>

                <p>Tổng Upload</p>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card report-card bg-success">

                <h1>@ViewBag.TotalUser</h1>

                <p>Người dùng</p>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card report-card bg-warning">

                <h1>@ViewBag.TotalJob</h1>

                <p>Công việc</p>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card report-card bg-danger">

                <h1>@ViewBag.TotalBlocked</h1>

                <p>Blocked IP</p>

            </div>

        </div>

    </div>

    <br />

    <div class="row">

        <div class="col-lg-6">

            <div class="card shadow">

                <div class="card-header">

                    🌍 Top 10 IP gửi CV

                </div>

                <table class="table table-hover">

                    <tr>

                        <th>IP</th>

                        <th>Số lần</th>

                    </tr>

                    @foreach (var item in ViewBag.TopIP)
                    {
                        <tr>

                            <td>@item.IP</td>

                            <td>@item.Total</td>

                        </tr>
                    }

                </table>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="card shadow">

                <div class="card-header">

                    💼 Top Job được ứng tuyển

                </div>

                <table class="table table-hover">

                    <tr>

                        <th>Job</th>

                        <th>Lượt ứng tuyển</th>

                    </tr>

                    @foreach (var item in ViewBag.TopJob)
                    {
                        <tr>

                            <td>@item.Job</td>

                            <td>@item.Total</td>

                        </tr>
                    }

                </table>

            </div>

        </div>

    </div>

</div>