@model IEnumerable<AnToanBaoMat.Models.Job>

@{
    ViewData["Title"] = "Quản lý Job";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">

        <h2>💼 Quản lý công việc</h2>

        <a asp-action="Create"
           class="btn btn-success">

            <i class="fa fa-plus"></i>

            Thêm Job

        </a>

    </div>

    <input id="searchJob"
           class="form-control mb-3"
           placeholder="🔍 Tìm Job..." />

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>ID</th>

                <th>Tên công việc</th>

                <th>Công ty</th>

                <th>Lương</th>

                <th>Hạn nộp</th>

                <th>Trạng thái</th>

                <th width="220">Thao tác</th>

            </tr>

        </thead>

        <tbody id="jobTable">

            @foreach (var item in Model)
            {

                <tr>

                    <td>@item.JobId</td>

                    <td>@item.JobTitle</td>

                    <td>@item.CompanyName</td>

                    <td>@String.Format("{0:N0}", item.Salary) VNĐ</td>

                    <td>@item.CreatedAt?.ToString("dd/MM/yyyy")</td>

                    <td>

                        <span class="badge bg-success">
                            Đang tuyển
                        </span>

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.JobId"
                           class="btn btn-warning btn-sm">

                            Sửa

                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.JobId"
                           class="btn btn-info btn-sm">

                            Chi tiết

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.JobId"
                           class="btn btn-danger btn-sm">

                            Xóa

                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>

<script>

    document.getElementById("searchJob").addEventListener("keyup",function(){

    let value=this.value.toLowerCase();

    document.querySelectorAll("#jobTable tr").forEach(function(r){

    r.style.display=r.innerText.toLowerCase().includes(value)
    ?"":"none";

    });

    });

</script>