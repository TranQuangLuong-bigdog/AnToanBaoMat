@{
    ViewData["Title"] = "Trang chủ";
}

<section class="hero">

    <!-- Grid nền -->
    <div class="hero-grid"></div>

    <div class="container">

        <div class="hero-content">

            <!-- LEFT -->
            <div class="hero-left">

                <span class="hero-badge">

                    <i class="fa-solid fa-shield-halved"></i>

                    CV SAFE

                </span>

                <h1>
                    GỬI CV AN TOÀN
                </h1>

                <h2>
                    Có kiểm tra IP bằng AI
                </h2>

                <p>
                    Hệ thống giúp doanh nghiệp và ứng viên
                    gửi CV nhanh chóng,
                    phát hiện IP bất thường,
                    chống spam,
                    bảo vệ dữ liệu
                    và ghi nhật ký upload.
                </p>

                <div class="hero-tags">

                    <span>
                        <i class="fa-solid fa-shield"></i>
                        Kiểm tra IP
                    </span>

                    <span>
                        <i class="fa-solid fa-ban"></i>
                        Chống Spam
                    </span>

                    <span>
                        <i class="fa-solid fa-lock"></i>
                        Bảo mật
                    </span>

                    <span>
                        <i class="fa-solid fa-chart-column"></i>
                        Nhật ký
                    </span>

                </div>

                <div class="hero-button">

                    <a href="#" class="btn btn-primary">
                        Bắt đầu ngay
                    </a>

                    <a href="#" class="btn btn-outline-light">
                        Xem tính năng
                    </a>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="hero-right">

                <!-- Glow -->
                <div class="hero-pulse"></div>

                <!-- Halo -->
                <div class="hero-halo"></div>

                <!-- Ring -->
                <div class="hero-line"></div>

                <div class="hero-line2"></div>

                <!-- Hero Image -->
                <img src="~/images/DASHBOARD.png"
                     alt="Security Hero">

                <!-- Card IP -->
                <div class="card-ip">

                    <i class="fa-solid fa-location-dot"></i>

                    <div>

                        <h4>KIỂM TRA IP</h4>

                        <p>
                            Tự động phát hiện
                            IP đáng ngờ
                        </p>

                    </div>

                </div>

                <!-- Card Security -->
                <div class="card-security">

                    <i class="fa-solid fa-lock"></i>

                    <div>

                        <h4>BẢO MẬT</h4>

                        <p>
                            Mã hóa dữ liệu
                            tuyệt đối
                        </p>

                    </div>

                </div>

                <!-- Card Spam -->
                <div class="card-spam">

                    <i class="fa-solid fa-user-shield"></i>

                    <div>

                        <h4>CHỐNG SPAM</h4>

                        <p>
                            Ngăn chặn
                            gửi CV hàng loạt
                        </p>

                    </div>

                </div>

                <!-- Card Log -->
                <div class="card-log">

                    <i class="fa-solid fa-chart-line"></i>

                    <div>

                        <h4>NHẬT KÝ</h4>

                        <p>
                            Theo dõi toàn bộ
                            hoạt động
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- =========================
        PARTNER
========================= -->
<!--======================================
        TRUSTED COMPANY
=======================================-->

<section class="partner">

    <div class="container">

        <div class="section-title">

            <span class="small-title">

                ĐỐI TÁC

            </span>

            <h2>

                Được doanh nghiệp tin tưởng

            </h2>

            <p>

                Hệ thống bảo mật được thiết kế dành cho
                doanh nghiệp tuyển dụng,
                trường đại học
                và nền tảng tuyển dụng trực tuyến.

            </p>

        </div>

        <div class="partner-wrapper">

            <div class="partner-item">

                <img src="~/images/viettel.png">

            </div>

            <div class="partner-item">

                <img src="~/images/fpt.png">

            </div>

            <div class="partner-item">

                <img src="~/images/google.png">

            </div>

            <div class="partner-item">

                <img src="~/images/cloudflare.png">

            </div>

            <div class="partner-item">

                <img src="~/images/topcv.png">

            </div>

            <div class="partner-item">

                <img src="~/images/jobstreet.png">

            </div>

        </div>

    </div>

</section>
<!--=====================================
        SECURITY FEATURE
======================================-->

<section class="feature-section" id="feature">

    <div class="container">

        <div class="section-title">

            <span class="small-title">

                SECURITY

            </span>

            <h2>

                Bảo vệ toàn diện cho hệ thống tuyển dụng

            </h2>

            <p>

                Hệ thống áp dụng nhiều lớp bảo mật giúp
                doanh nghiệp tuyển dụng an toàn,
                ngăn chặn các hành vi spam,
                bảo vệ dữ liệu ứng viên
                và theo dõi toàn bộ hoạt động.

            </p>

        </div>

        <div class="feature-grid">

            <!-- Card 1 -->

            <a asp-controller="BlockedIp"
               asp-action="Index"
               class="feature-box text-decoration-none">

                <div class="icon-box">

                    <i class="fa-solid fa-shield-halved"></i>

                </div>

                <h3>

                    Kiểm tra IP

                </h3>

                <p>

                    Phát hiện địa chỉ IP bất thường,
                    kiểm tra IP nằm trong danh sách chặn.

                </p>

            </a>

            <!-- Card 2 -->

            <a asp-controller="Security"
               asp-action="Index"
               class="feature-box text-decoration-none">
                <div class="icon-box">

                    <i class="fa-solid fa-lock"></i>

                </div>

                <h3>

                    Mã hóa dữ liệu

                </h3>

                <p>

                    Thông tin ứng viên và CV được lưu
                    an toàn,
                    hạn chế rò rỉ dữ liệu.

                </p>

            </a>

            <!-- Card 3 -->

            <a asp-controller="Application"
               asp-action="Upload"
               class="feature-box text-decoration-none">
                <div class="icon-box">

                    <i class="fa-solid fa-user-shield"></i>

                </div>

                <h3>

                    Chống Spam

                </h3>

                <p>

                    Giới hạn số lần gửi CV,
                    ngăn bot tự động
                    và upload hàng loạt.

                </p>

            </a>

            <!-- Card 4 -->

            <a asp-controller="CvUploadLog"
               asp-action="Index"
               class="feature-box text-decoration-none">
                <div class="icon-box">

                    <i class="fa-solid fa-chart-line"></i>

                </div>

                <h3>

                    Nhật ký Upload

                </h3>

                <p>

                    Lưu lại thời gian,
                    IP,
                    trạng thái upload
                    để dễ dàng kiểm tra.

                </p>

            </a>

            <!-- Card 5 -->

            <a asp-controller="Security"
               asp-action="Attack"
               class="feature-box text-decoration-none">
                <div class="icon-box">

                    <i class="fa-solid fa-brain"></i>

                </div>

                <h3>

                    AI Phân tích

                </h3>

                <p>

                    AI hỗ trợ nhận diện
                    hành vi bất thường
                    trong quá trình gửi CV.

                </p>

            </a>

            <!-- Card 6 -->

            <a asp-controller="Dashboard"
               asp-action="Index"
               class="feature-box text-decoration-none">
                <div class="icon-box">

                    <i class="fa-solid fa-cloud"></i>

                </div>

                <h3>

                    Cloud Security

                </h3>

                <p>

                    Dữ liệu được lưu trữ
                    an toàn,
                    sao lưu
                    và phục hồi nhanh chóng.

                </p>

            </a>

        </div>

    </div>

</section>
<!--=====================================
        UPLOAD PROCESS
======================================-->

<section class="process-section" id="process">

    <div class="container">

        <div class="section-title">

            <span class="small-title">

                QUY TRÌNH

            </span>

            <h2>

                Quy trình gửi CV an toàn

            </h2>

            <p>

                Mỗi CV đều trải qua nhiều lớp kiểm tra trước khi được lưu vào hệ thống.

            </p>

        </div>

        <div class="process-grid">

            <div class="process-item">

                <div class="process-icon">

                    <i class="fa-solid fa-file-arrow-up"></i>

                </div>

                <h4>Upload CV</h4>

                <p>Người dùng chọn CV và công việc muốn ứng tuyển.</p>

            </div>

            <div class="process-arrow">

                <i class="fa-solid fa-arrow-right"></i>

            </div>

            <div class="process-item">

                <div class="process-icon">

                    <i class="fa-solid fa-location-dot"></i>

                </div>

                <h4>Kiểm tra IP</h4>

                <p>Đối chiếu với danh sách IP bị chặn và phát hiện IP bất thường.</p>

            </div>

            <div class="process-arrow">

                <i class="fa-solid fa-arrow-right"></i>

            </div>

            <div class="process-item">

                <div class="process-icon">

                    <i class="fa-solid fa-user-shield"></i>

                </div>

                <h4>Chống Spam</h4>

                <p>Giới hạn số lần gửi CV trong khoảng thời gian nhất định.</p>

            </div>

            <div class="process-arrow">

                <i class="fa-solid fa-arrow-right"></i>

            </div>

            <div class="process-item">

                <div class="process-icon">

                    <i class="fa-solid fa-database"></i>

                </div>

                <h4>Lưu dữ liệu</h4>

                <p>Lưu CV và ghi nhật ký upload để theo dõi.</p>

            </div>

        </div>

    </div>

</section>
<!--=====================================
        DASHBOARD PREVIEW
======================================-->

<section class="dashboard-preview" id="dashboard">

    <div class="container">

        <div class="row align-items-center">

            <!-- LEFT -->

            <div class="col-lg-5">

                <span class="small-title">

                    DASHBOARD

                </span>

                <h2>

                    Theo dõi hệ thống theo thời gian thực

                </h2>

                <p>

                    Dashboard hiển thị số lượng CV đã gửi,
                    IP bị chặn,
                    nhật ký upload,
                    thống kê truy cập
                    và các cảnh báo bảo mật giúp quản trị viên
                    kiểm soát hệ thống dễ dàng.

                </p>

                <ul class="dashboard-list">

                    <li>

                        <i class="fa-solid fa-circle-check"></i>

                        Thống kê Upload CV

                    </li>

                    <li>

                        <i class="fa-solid fa-circle-check"></i>

                        Theo dõi IP bất thường

                    </li>

                    <li>

                        <i class="fa-solid fa-circle-check"></i>

                        Báo cáo thời gian thực

                    </li>

                    <li>

                        <i class="fa-solid fa-circle-check"></i>

                        Phân tích AI

                    </li>

                </ul>

            </div>

            <!-- RIGHT -->

            <div class="col-lg-7">

                <div class="dashboard-card">

                    <img src="~/images/dashboard.png"
                         class="img-fluid">

                </div>

            </div>

        </div>

    </div>

</section>
