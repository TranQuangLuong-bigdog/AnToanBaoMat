@{
    ViewData["Title"] = "Xác thực OTP";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white text-center py-4">

                    <h2>🛡 CV SAFE</h2>

                    <h5 class="mt-2">
                        Xác thực OTP
                    </h5>

                </div>

                <div class="card-body p-4">

                    <p class="text-center text-muted">

                        Mã OTP đã được gửi tới Email của bạn.

                    </p>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">

                            @TempData["Error"]

                        </div>
                    }

                    <form asp-action="VerifyOTP" method="post">

                        <input type="hidden"
                               name="applicationId"
                               value="@ViewBag.ApplicationId" />

                        <label class="fw-bold">

                            Nhập mã OTP

                        </label>

                        <input class="form-control form-control-lg text-center mt-2"
                               maxlength="6"
                               name="otp"
                               autocomplete="off"
                               placeholder="••••••" />

                        <div class="mt-3 text-center">

                            <small class="text-secondary">

                                ⏱ OTP có hiệu lực trong 5 phút

                            </small>

                        </div>

                        <button class="btn btn-success btn-lg w-100 mt-4">

                            ✔ Xác nhận OTP

                        </button>

                    </form>

                    <hr />

                    <div class="text-center">

                        <a asp-action="SendOTP"
                           asp-route-id="@ViewBag.ApplicationId">

                            🔄 Gửi lại OTP

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>